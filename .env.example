# ===================================================================
# Star Modern Diagnostic Laboratory — environment variables
# ===================================================================
#
# Copy this file to `.env.local` (for local dev) or `.env.production`
# (used during `npm run build`). Variables prefixed with NEXT_PUBLIC_
# are inlined into the static build at build time.
# -------------------------------------------------------------------

# Web3Forms access key — required for the contact form to email you.
#
# How to get one (free, takes 30 seconds):
#   1. Go to https://web3forms.com
#   2. Enter your email and click "Create Access Key"
#   3. Copy the key here. Submissions will email straight to that address.
#
# If you leave this blank, the contact form falls back to opening the
# visitor's mail client with a pre-filled message — the site never breaks.
NEXT_PUBLIC_WEB3FORMS_KEY=
